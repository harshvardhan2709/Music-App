{
  "expo": {
    "name": "my-app",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",

    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "permissions": ["READ_EXTERNAL_STORAGE", "READ_MEDIA_AUDIO"],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.harsh2004.myapp"
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router", "expo-splash-screen", "expo-audio"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
